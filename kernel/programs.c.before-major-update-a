static program_t program_table[] = {
    {"HELLO",  "Print hello message and arguments", program_hello},
    {"CLOCK",  "Show timer ticks and uptime",       program_clock},
    {"MEM",    "Show heap memory information",      program_mem},
    {"FILES",  "Show RAM filesystem summary",       program_files},
    {"COLORS", "Show VGA text colors",              program_colors},
    {"ABOUT",  "Show program system information",   program_about}
};

#define PROGRAM_COUNT (sizeof(program_table) / sizeof(program_table[0]))

void init_programs() {
    programs_ready = 1;
    last_program_result = -1;
    last_program_start_ticks = 0;
    last_program_end_ticks = 0;
    last_program_name[0] = '\0';
    last_program_args[0] = '\0';
}

int program_count() {
    return (int)PROGRAM_COUNT;
}

void program_help() {
    kprint("Program manager commands:\n");
    kprint("PROGRAMS              - List internal programs\n");
    kprint("PROGS                 - Alias for PROGRAMS\n");
    kprint("PROGRAM HELP          - Show this help\n");
    kprint("PROGRAM COUNT         - Show internal program count\n");
    kprint("PROGRAM STATUS        - Show last program run status\n");
    kprint("PROGRAM INFO NAME     - Show program information\n");
    kprint("PROGRAM INFO ALL      - Show all program details\n");
    kprint("RUNPROG NAME          - Run internal program\n");
    kprint("RUNPROG NAME ARGS     - Run internal program with arguments\n");
    kprint("EXEC NAME             - Alias for RUNPROG\n");
}

void program_list() {
    unsigned int i;

    if (!programs_ready) {
        kprint("Program manager is not initialized.\n");
        return;
    }

    kprint("Internal programs:\n");

    for (i = 0; i < PROGRAM_COUNT; i++) {
        kprint(program_table[i].name);
        kprint(" - ");
        kprint(program_table[i].description);
        kprint("\n");
    }
}

static void print_one_program_info(unsigned int i) {
    kprint("Program name: ");
    kprint(program_table[i].name);
    kprint("\n");

    kprint("Description: ");
    kprint(program_table[i].description);
    kprint("\n");

    kprint("Type: internal kernel-managed program\n");
}

void program_info(char *name) {
    unsigned int i;

    if (name == 0 || name[0] == '\0') {
        kprint("Usage: PROGRAM INFO NAME\n");
        return;
    }

    if (strcmp_ignore_case(name, "ALL") == 0) {
        kprint("All internal program details:\n");

        for (i = 0; i < PROGRAM_COUNT; i++) {
            print_one_program_info(i);
            kprint("\n");
        }

        return;
    }

    for (i = 0; i < PROGRAM_COUNT; i++) {
        if (strcmp_ignore_case(name, program_table[i].name) == 0) {
            print_one_program_info(i);
            return;
        }
    }

    kprint("Program not found.\n");
}

void program_status() {
    kprint("Program manager status:\n");

    kprint("Initialized: ");
    if (programs_ready) {
        kprint("yes\n");
    } else {
        kprint("no\n");
    }

    kprint("Program count: ");
    print_uint_local((u32)PROGRAM_COUNT);
    kprint("\n");

    kprint("Last program: ");
    if (last_program_name[0] == '\0') {
        kprint("none\n");
    } else {
        kprint(last_program_name);
        kprint("\n");
    }

    kprint("Last arguments: ");
    if (last_program_args[0] == '\0') {
        kprint("none\n");
    } else {
        kprint(last_program_args);
        kprint("\n");
    }

    kprint("Last result: ");
    if (last_program_result == 1) {
        kprint("success\n");
    } else if (last_program_result == 0) {
        kprint("failed\n");
    } else {
        kprint("not run yet\n");
    }

    kprint("Last start ticks: ");
    print_uint_local(last_program_start_ticks);
    kprint("\n");

    kprint("Last end ticks: ");
    print_uint_local(last_program_end_ticks);
    kprint("\n");

    kprint("Last duration ticks: ");
    if (last_program_end_ticks >= last_program_start_ticks) {
        print_uint_local(last_program_end_ticks - last_program_start_ticks);
    } else {
        print_uint_local(0);
    }
    kprint("\n");
}

int program_run(char *name, char *args) {
    unsigned int i;
    int pid;

    if (!programs_ready) {
        kprint("Program manager is not initialized.\n");
        last_program_result = 0;
        return 0;
    }

    if (name == 0 || name[0] == '\0') {
        kprint("Usage: RUNPROG NAME\n");
        last_program_result = 0;
        return 0;
    }

    for (i = 0; i < PROGRAM_COUNT; i++) {
        if (strcmp_ignore_case(name, program_table[i].name) == 0) {
            copy_string_limited_local(last_program_name, program_table[i].name, 32);
            copy_string_limited_local(last_program_args, args, 128);

            last_program_start_ticks = get_timer_ticks();

            pid = process_start(program_table[i].name, args);

            kprint("Running program: ");
            kprint(program_table[i].name);
            kprint("\n");

            if (pid > 0) {
                kprint("PID: ");
                print_uint_local((u32)pid);
                kprint("\n");
            }

            if (args != 0 && args[0] != '\0') {
                kprint("Program args: ");
                kprint(args);
                kprint("\n");
            }

            program_table[i].entry(args);

            last_program_end_ticks = get_timer_ticks();
            last_program_result = 1;

            if (pid > 0) {
                process_finish(pid, 1);
            }

            kprint("Program finished.\n");
            return 1;
        }
    }

    copy_string_limited_local(last_program_name, name, 32);
    copy_string_limited_local(last_program_args, args, 128);
    last_program_start_ticks = get_timer_ticks();
    last_program_end_ticks = last_program_start_ticks;
    last_program_result = 0;

    pid = process_start(name, args);

    if (pid > 0) {
        process_finish(pid, 0);
    }

    kprint("Program not found. Use PROGRAMS.\n");
    return 0;
}