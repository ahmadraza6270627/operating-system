static void program_about(char *args) {
    args = args;

    kprint("ABOUT program\n");
    kprint("Simple_OS / MyOS internal program manager v2.\n");
    kprint("These are kernel-managed programs, not real user-mode apps yet.\n");
    kprint("This layer prepares the shell for future external/user programs.\n");
